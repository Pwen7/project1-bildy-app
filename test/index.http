  "password": "1"
}

### 2. verifyEmail: change "code"
PUT {{base}}/validation
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "code": "663407"
}

### freelanceUser
PUT {{base}}/validation
Content-Type: application/json
Authorization: Bearer {{tokenFreelance}}

{
  "code": "471470"
}

### incorrect code: 400
PUT {{base}}/validation
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "code": "PEGAR_CODIGO_DE_6_DIGITOS"
}

### no token: 401
PUT {{base}}/validation
Content-Type: application/json

{
  "code": "123456"
}

### 3. loginUser
### ↑ update @tokenTest and @refreshTokenTest ↑
POST {{base}}/login
Content-Type: application/json

{
  "email": "carlos@example.com",
  "password": "carlosPass123"
}

### email not registered and wrang password: 401
POST {{base}}/login
Content-Type: application/json

{
  "email": "mail@example.com",
  "password": "wrong"
}

### 4.1. updateUserData
### userTest
PUT {{base}}/register
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "name": "Carlos",
  "lastName": "García",
  "nif": "12345678A"
}

### userAdmin
PUT {{base}}/register
Content-Type: application/json
Authorization: Bearer {{tokenAdmin}}

{
  "name": "Pedro",
  "lastName": "López",
  "nif": "00000001A"
}

### userFreelance
PUT {{base}}/register
Content-Type: application/json
Authorization: Bearer {{tokenFreelance}}

{
  "name": "Sara",
  "lastName": "Rodríguez",
  "nif": "00000002B"
}

### 4.2.a upsertCompany: new company
PATCH {{base}}/company
Content-Type: application/json
Authorization: Bearer {{tokenAdmin}}

{
  "isFreelance": false,
  "name": "U-tad",
  "cif": "B12345678",
  "address": {
    "street": "Playa de Liencres",
    "number": "2",
    "postal": "28290",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 4.2.b upsertCompany: existing company (same cif)
PATCH {{base}}/company
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "isFreelance": false,
  "name": "Empresa Existente",
  "cif": "B12345678",
  "address": {
    "street": "Otra Calle",
    "number": "5",
    "postal": "28002",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 4.2.c upsertCompany: freelanceUser company
PATCH {{base}}/company
Content-Type: application/json
Authorization: Bearer {{tokenFreelance}}

{
  "isFreelance": true
}

### 5. uploadLogo .png
PATCH {{base}}/logo
Authorization: Bearer {{tokenTest}}
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="logo"; filename="utad.png"
Content-Type: image/png

< ./utad.png
------Boundary--

### .jpg
PATCH {{base}}/logo
Authorization: Bearer {{tokenFreelance}}
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="logo"; filename="ucjc.jpg"
Content-Type: image/jpg

< ./ucjc.jpg
------Boundary--

### not allowed extension: 400
PATCH {{base}}/logo
Authorization: Bearer {{tokenTest}}
Content-Type: multipart/form-data; boundary=----Boundary

------Boundary
Content-Disposition: form-data; name="logo"; filename="document.pdf"
Content-Type: application/pdf

< ./document.pdf
------Boundary--

### 6. getUser
GET {{base}}
Authorization: Bearer {{tokenTest}}

### freelanceUser
GET {{base}}
Authorization: Bearer {{tokenFreelance}}

### 7.1. refreshToken
### ↑ update @tokenTest and @refreshTokenTest ↑
POST {{base}}/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshTokenTest}}"
}

### invalid refresh token: 401
POST {{base}}/refresh
Content-Type: application/json

{
  "refreshToken": "token"
}

### 7.2. logoutUser
POST {{base}}/logout
Authorization: Bearer {{tokenTest}}

### 9. changePassword
PUT {{base}}/password
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "currentPassword": "carlosPass123",
  "newPassword": "newCarlosPass123"
}

### same password: 400
PUT {{base}}/password
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "currentPassword": "newCarlosPass123",
  "newPassword": "newCarlosPass123"
}

### 10. inviteUser
POST {{base}}/invite
Content-Type: application/json
Authorization: Bearer {{tokenAdmin}}

{
  "email": "ana@example.com",
  "name": "Ana",
  "lastName": "Sierra",
  "password": "anaPass123"
}

### guest user invitation: 403
POST {{base}}/invite
Content-Type: application/json
Authorization: Bearer {{tokenTest}}

{
  "email": "ana@example.com",
  "name": "Ana",
  "lastName": "Sierra",
  "password": "anaPass123"
}

### 8. deleteUser
### soft delete
DELETE {{base}}?soft=true
Authorization: Bearer {{tokenAdmin}}

### hard delete
DELETE {{base}}
Authorization: Bearer {{tokenTest}}
