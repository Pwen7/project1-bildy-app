# Server
PORT=3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=development

# MongoDB
DB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT
JWT_SECRET=tu-clave-super-secreta-de-al-menos-32-caracteres
JWT_EXPIRES_IN=15min
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Nodemailer (usa Mailtrap en dev)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass

# Slack webhook para alertas 5XX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
