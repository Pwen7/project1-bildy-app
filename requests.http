### DELIVERY NOTES
### 27.
POST {{base}}/deliverynote
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "client": "{{clientId}}",
  "format": "hours",
  "description": "Jornada de pintura interior",
  "workDate": "2025-06-15",
  "workers": [
    { "name": "Carlos López", "hours": 8 },
    { "name": "Ana Martínez", "hours": 6 }
  ]
}

### 27b.
POST {{base}}/deliverynote
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "client": "{{clientId}}",
  "format": "hours",
  "description": "Jornada de replanteo",
