  "unit": "kg"
}

### 29. listar
GET {{base}}/deliverynote?page=1&limit=10&sort=-workDate
Authorization: Bearer {{token}}

### 29b.
GET {{base}}/deliverynote?project={{projectId}}&page=1&limit=10
Authorization: Bearer {{token}}

### 29c.
GET {{base}}/deliverynote?client={{clientId}}&page=1&limit=10
Authorization: Bearer {{token}}

### 29d. por formato
GET {{base}}/deliverynote?format=hours&page=1&limit=10
Authorization: Bearer {{token}}

### 29e. no firmados
GET {{base}}/deliverynote?signed=false&page=1&limit=10
Authorization: Bearer {{token}}

###

### 29f. rango
GET {{base}}/deliverynote?from=2025-01-01&to=2025-12-31&page=1&limit=10
Authorization: Bearer {{token}}

### 30.
GET {{base}}/deliverynote/{{noteId}}
Authorization: Bearer {{token}}

### 31. descargar
