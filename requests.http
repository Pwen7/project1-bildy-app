  "hours": 4
}

### 28.
POST {{base}}/deliverynote
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "project": "{{projectId}}",
  "client": "{{clientId}}",
  "format": "material",
  "description": "Suministro cemento",
  "workDate": "2025-06-15",
  "material": "Cemento Portland",
